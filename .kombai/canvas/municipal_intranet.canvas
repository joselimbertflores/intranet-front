      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&family=Roboto:wght@300;400;500&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  body {\n    font-family: 'Roboto', sans-serif;\n    color: #1e293b;\n    background-color: #ffffff;\n    margin: 0;\n  }\n\n  .font-outfit {\n    font-family: 'Outfit', sans-serif;\n  }\n\n  .wave-pattern {\n    mask-image: url('https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/waves.svg');\n    mask-repeat: no-repeat;\n    mask-position: center;\n    mask-size: cover;\n    opacity: 0.05;\n  }\n</style>\n\n<div class=\"min-h-screen\" data-kid=\"1\">\n  \n  <header class=\"sticky top-4 z-50 mx-auto max-w-7xl px-4\" data-kid=\"2\">\n    <div class=\"flex items-center justify-between rounded-full bg-white/80 px-8 py-3 shadow-lg backdrop-blur-md\" data-kid=\"3\">\n      \n      <nav class=\"hidden flex-1 items-center gap-8 lg:flex\" data-kid=\"4\">\n        <a href=\"#\" class=\"font-outfit text-sm font-semibold tracking-wide text-teal-700 transition-colors hover:text-emerald-600\" data-kid=\"5\">INICIO</a>\n        <a href=\"#\" class=\"font-outfit text-sm font-semibold tracking-wide text-slate-600 transition-colors hover:text-teal-700\" data-kid=\"6\">CIUDAD</a>\n        <a href=\"#\" class=\"font-outfit text-sm font-semibold tracking-wide text-slate-600 transition-colors hover:text-teal-700\" data-kid=\"7\">TRAMITES</a>\n      </nav>\n\n      \n      <div class=\"flex flex-shrink-0 items-center gap-3\" data-kid=\"8\">\n        <div class=\"flex h-12 w-12 items-center justify-center rounded-full bg-teal-50\" data-kid=\"9\">\n          <img src=\"/api/local/images/public/images/institution/institution-logo.png\" alt=\"Escudo Municipal\" class=\"h-8 w-8 object-contain\" onerror=\"this.src='https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/shield-comb.svg'; this.style.filter='invert(41%) sepia(87%) saturate(452%) hue-rotate(125deg) brightness(92%) contrast(92%)';\" data-kid=\"10\">\n        </div>\n        <div class=\"flex flex-col\" data-kid=\"11\">\n          <span class=\"font-outfit text-lg font-bold leading-none tracking-tight text-teal-900\" data-kid=\"12\">MUNICIPALIDAD</span>\n          <span class=\"font-outfit text-xs font-medium tracking-[0.2em] text-emerald-600 uppercase\" data-kid=\"13\">Intranet Pública</span>\n        </div>\n      </div>\n\n      \n      <div class=\"flex flex-1 items-center justify-end gap-6\" data-kid=\"14\">\n        <button class=\"text-slate-500 transition-colors hover:text-teal-700\" data-kid=\"15\">\n          <i class=\"ti ti-search text-2xl\" data-kid=\"16\"></i>\n        </button>\n        <button class=\"font-outfit flex items-center gap-2 rounded-full bg-emerald-600 px-6 py-2.5 text-sm font-bold tracking-wide text-white shadow-md transition-all hover:bg-emerald-700 hover:shadow-lg active:scale-95\" data-kid=\"17\">\n          <i class=\"ti ti-login text-lg\" data-kid=\"18\"></i>\n          ACCESO INTERNO\n        </button>\n      </div>\n    </div>\n  </header>\n\n  <main class=\"mx-auto mt-8 max-w-7xl px-4 pb-20\" data-kid=\"19\">\n    \n    <section class=\"relative aspect-[16/5] w-full overflow-hidden rounded-[24px] shadow-2xl\" data-kid=\"20\">\n      <img src=\"https://images.unsplash.com/photo-1761002067292-a89ed4f4fa68?auto=format&w=1280&q=80&fit=crop\" alt=\"Vista aérea de la infraestructura moderna de la ciudad por Leo_Visions en Unsplash\" class=\"h-full w-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"21\">\n      <div class=\"absolute inset-0 bg-gradient-to-t from-slate-900/80 via-transparent to-transparent\" data-kid=\"22\"></div>\n      \n      <div class=\"absolute bottom-12 left-12 max-w-xl\" data-kid=\"23\">\n        <h1 class=\"font-outfit text-5xl font-bold tracking-tight text-white drop-shadow-lg\" data-kid=\"24\">Innovación y Sostenibilidad</h1>\n        <p class=\"mt-4 text-xl font-light text-slate-100 drop-shadow-md\" data-kid=\"25\">Construyendo juntos la ciudad inteligente del futuro, centrada en el bienestar de cada ciudadano.</p>\n        <button class=\"font-outfit mt-8 rounded-full border-2 border-white/80 px-8 py-3 text-sm font-bold tracking-widest text-white backdrop-blur-sm transition-all hover:bg-white hover:text-teal-900\" data-kid=\"26\">\n          VER PROYECTOS\n        </button>\n      </div>\n\n      \n      <div class=\"absolute bottom-6 left-1/2 flex -translate-x-1/2 items-center gap-2 rounded-full bg-white/20 px-4 py-2 backdrop-blur-md\" data-kid=\"27\">\n        <div class=\"h-2 w-8 rounded-full bg-white\" data-kid=\"28\"></div>\n        <div class=\"h-2 w-2 rounded-full bg-white/40\" data-kid=\"29\"></div>\n        <div class=\"h-2 w-2 rounded-full bg-white/40\" data-kid=\"30\"></div>\n      </div>\n    </section>\n\n    \n    <section class=\"mt-16\" data-kid=\"31\">\n      <div class=\"flex items-end justify-between\" data-kid=\"32\">\n        <div data-kid=\"33\">\n          <h2 class=\"font-outfit text-3xl font-bold tracking-tight text-slate-900\" data-kid=\"34\">Trámites Destacados</h2>\n          <p class=\"mt-2 text-slate-500\" data-kid=\"35\">Gestiones rápidas y servicios digitales para tu comodidad.</p>\n        </div>\n        <a href=\"#\" class=\"font-outfit flex items-center gap-2 text-sm font-bold text-teal-700 hover:text-emerald-600\" data-kid=\"36\">\n          VER TODOS LOS SERVICIOS <i class=\"ti ti-arrow-right\" data-kid=\"37\"></i>\n        </a>\n      </div>\n\n      <div class=\"mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4\" data-kid=\"38\">\n        \n        <div class=\"group relative overflow-hidden rounded-3xl bg-teal-50/50 p-8 transition-all hover:bg-teal-50\" data-kid=\"39\">\n          <div class=\"wave-pattern absolute inset-0\" data-kid=\"40\"></div>\n          <div class=\"relative z-10\" data-kid=\"41\">\n            <i class=\"ti ti-clipboard-list text-4xl text-emerald-600\" data-kid=\"42\"></i>\n            <h3 class=\"font-outfit mt-6 text-xl font-bold text-teal-900\" data-kid=\"43\">Gestión en Línea</h3>\n            <p class=\"mt-3 text-sm leading-relaxed text-slate-600\" data-kid=\"44\">Realiza tus solicitudes y pagos de impuestos de forma segura desde casa.</p>\n          </div>\n        </div>\n        \n        <div class=\"group relative overflow-hidden rounded-3xl bg-teal-50/50 p-8 transition-all hover:bg-teal-50\" data-kid=\"45\">\n          <div class=\"wave-pattern absolute inset-0\" style=\"mask-image: url('https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/wave-crest.svg')\" data-kid=\"46\"></div>\n          <div class=\"relative z-10\" data-kid=\"47\">\n            <i class=\"ti ti-home text-4xl text-emerald-600\" data-kid=\"48\"></i>\n            <h3 class=\"font-outfit mt-6 text-xl font-bold text-teal-900\" data-kid=\"49\">Desarrollo Urbano</h3>\n            <p class=\"mt-3 text-sm leading-relaxed text-slate-600\" data-kid=\"50\">Consulta de planes territoriales, permisos de construcción y zonificación.</p>\n          </div>\n        </div>\n        \n        <div class=\"group relative overflow-hidden rounded-3xl bg-teal-50/50 p-8 transition-all hover:bg-teal-50\" data-kid=\"51\">\n          <div class=\"wave-pattern absolute inset-0\" style=\"mask-image: url('https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/wave-strike.svg')\" data-kid=\"52\"></div>\n          <div class=\"relative z-10\" data-kid=\"53\">\n            <i class=\"ti ti-tree-pine text-4xl text-emerald-600\" data-kid=\"54\"></i>\n            <h3 class=\"font-outfit mt-6 text-xl font-bold text-teal-900\" data-kid=\"55\">Medio Ambiente</h3>\n            <p class=\"mt-3 text-sm leading-relaxed text-slate-600\" data-kid=\"56\">Iniciativas ecológicas, recolección de residuos y gestión de áreas verdes.</p>\n          </div>\n        </div>\n        \n        <div class=\"group relative overflow-hidden rounded-3xl bg-teal-50/50 p-8 transition-all hover:bg-teal-50\" data-kid=\"57\">\n          <div class=\"wave-pattern absolute inset-0\" style=\"mask-image: url('https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/big-wave.svg')\" data-kid=\"58\"></div>\n          <div class=\"relative z-10\" data-kid=\"59\">\n            <i class=\"ti ti-shield text-4xl text-emerald-600\" data-kid=\"60\"></i>\n            <h3 class=\"font-outfit mt-6 text-xl font-bold text-teal-900\" data-kid=\"61\">Seguridad</h3>\n            <p class=\"mt-3 text-sm leading-relaxed text-slate-600\" data-kid=\"62\">Reportes ciudadanos, programas de prevención y centros de atención.</p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"mt-20\" data-kid=\"63\">\n      <h2 class=\"font-outfit text-3xl font-bold tracking-tight text-slate-900\" data-kid=\"64\">Actualidad Municipal</h2>\n      <div class=\"mt-8 flex flex-col gap-8 lg:flex-row\" data-kid=\"65\">\n        \n        <div class=\"group relative flex-1 overflow-hidden rounded-3xl shadow-lg lg:basis-3/5\" data-kid=\"66\">\n          <img src=\"https://images.pexels.com/photos/34708809/pexels-photo-34708809.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Inauguración del nuevo centro comunitario por Francisco Medellin en Pexels\" class=\"h-[400px] w-full object-cover transition-transform duration-700 group-hover:scale-105\" decoding=\"async\" loading=\"lazy\" data-kid=\"67\">\n          <div class=\"absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent\" data-kid=\"68\"></div>\n          <div class=\"absolute bottom-8 left-8 right-8\" data-kid=\"69\">\n            <span class=\"inline-block rounded-full bg-emerald-600 px-4 py-1 text-xs font-bold text-white uppercase\" data-kid=\"70\">Infraestructura</span>\n            <h3 class=\"font-outfit mt-4 text-3xl font-bold text-white\" data-kid=\"71\">Inauguración del Nuevo Centro Comunitario Municipal</h3>\n            <p class=\"mt-3 text-slate-200\" data-kid=\"72\">Un espacio moderno diseñado para el encuentro social, la cultura y el deporte de todos nuestros vecinos.</p>\n          </div>\n        </div>\n\n        \n        <div class=\"flex flex-col gap-6 lg:basis-2/5\" data-kid=\"73\">\n          <div class=\"flex flex-col gap-2 rounded-2xl bg-slate-50 p-6 transition-colors hover:bg-teal-50\" data-kid=\"74\">\n            <span class=\"font-outfit text-xs font-bold tracking-widest text-teal-700 uppercase\" data-kid=\"75\">Cultura</span>\n            <h4 class=\"font-outfit text-xl font-bold text-slate-900\" data-kid=\"76\">Festival de Verano 2024: Conoce la programación completa</h4>\n            <p class=\"text-sm text-slate-500\" data-kid=\"77\">Más de 50 artistas locales e internacionales se darán cita en los parques de la ciudad...</p>\n          </div>\n          <div class=\"flex flex-col gap-2 rounded-2xl bg-slate-50 p-6 transition-colors hover:bg-teal-50\" data-kid=\"78\">\n            <span class=\"font-outfit text-xs font-bold tracking-widest text-teal-700 uppercase\" data-kid=\"79\">Salud</span>\n            <h4 class=\"font-outfit text-xl font-bold text-slate-900\" data-kid=\"80\">Campaña de Vacunación Itinerante en Barrios del Norte</h4>\n            <p class=\"text-sm text-slate-500\" data-kid=\"81\">Durante toda la semana, nuestras unidades móviles estarán brindando atención gratuita...</p>\n          </div>\n          <div class=\"flex flex-col gap-2 rounded-2xl bg-slate-50 p-6 transition-colors hover:bg-teal-50\" data-kid=\"82\">\n            <span class=\"font-outfit text-xs font-bold tracking-widest text-teal-700 uppercase\" data-kid=\"83\">Transparencia</span>\n            <h4 class=\"font-outfit text-xl font-bold text-slate-900\" data-kid=\"84\">Rendición de Cuentas: Informe Trimestral de Gestión</h4>\n            <p class=\"text-sm text-slate-500\" data-kid=\"85\">Ya se encuentra disponible el reporte detallado sobre la ejecución del presupuesto anual...</p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <div class=\"mt-20 grid grid-cols-1 gap-12 lg:grid-cols-2\" data-kid=\"86\">\n      \n      <section data-kid=\"87\">\n        <div class=\"flex items-center justify-between\" data-kid=\"88\">\n          <h2 class=\"font-outfit text-2xl font-bold tracking-tight text-slate-900\" data-kid=\"89\">Participación Ciudadana</h2>\n          <div class=\"flex gap-2\" data-kid=\"90\">\n            <button class=\"flex h-8 w-8 items-center justify-center rounded-full bg-slate-100 text-slate-400 hover:bg-teal-100 hover:text-teal-700\" data-kid=\"91\">\n              <i class=\"ti ti-chevron-left\" data-kid=\"92\"></i>\n            </button>\n            <button class=\"flex h-8 w-8 items-center justify-center rounded-full bg-slate-100 text-slate-400 hover:bg-teal-100 hover:text-teal-700\" data-kid=\"93\">\n              <i class=\"ti ti-chevron-right\" data-kid=\"94\"></i>\n            </button>\n          </div>\n        </div>\n        <div class=\"mt-6 space-y-4\" data-kid=\"95\">\n          <div class=\"group flex items-center gap-6 rounded-3xl bg-white p-4 shadow-sm transition-all hover:shadow-emerald-100 hover:shadow-xl\" data-kid=\"96\">\n            <div class=\"flex h-16 w-16 flex-col items-center justify-center rounded-2xl bg-teal-50 text-teal-700\" data-kid=\"97\">\n              <span class=\"text-xl font-bold\" data-kid=\"98\">15</span>\n              <span class=\"text-[10px] font-bold uppercase\" data-kid=\"99\">JUL</span>\n            </div>\n            <div class=\"flex-1\" data-kid=\"100\">\n              <h4 class=\"font-outfit font-bold text-slate-900\" data-kid=\"101\">Audiencia Pública: Plan de Ordenamiento</h4>\n              <p class=\"text-sm text-slate-500\" data-kid=\"102\"><i class=\"ti ti-map-pin\" data-kid=\"103\"></i> Salón Consistorial, 18:00 hrs</p>\n            </div>\n            <i class=\"ti ti-chevron-right text-slate-300 group-hover:text-emerald-600\" data-kid=\"104\"></i>\n          </div>\n          <div class=\"group flex items-center gap-6 rounded-3xl bg-white p-4 shadow-sm transition-all hover:shadow-emerald-100 hover:shadow-xl\" data-kid=\"105\">\n            <div class=\"flex h-16 w-16 flex-col items-center justify-center rounded-2xl bg-teal-50 text-teal-700\" data-kid=\"106\">\n              <span class=\"text-xl font-bold\" data-kid=\"107\">22</span>\n              <span class=\"text-[10px] font-bold uppercase\" data-kid=\"108\">JUL</span>\n            </div>\n            <div class=\"flex-1\" data-kid=\"109\">\n              <h4 class=\"font-outfit font-bold text-slate-900\" data-kid=\"110\">Taller de Huertos Urbanos Comunitarios</h4>\n              <p class=\"text-sm text-slate-500\" data-kid=\"111\"><i class=\"ti ti-map-pin\" data-kid=\"112\"></i> Parque Central, 10:00 hrs</p>\n            </div>\n            <i class=\"ti ti-chevron-right text-slate-300 group-hover:text-emerald-600\" data-kid=\"113\"></i>\n          </div>\n        </div>\n      </section>\n\n      \n      <section data-kid=\"114\">\n        <h2 class=\"font-outfit text-2xl font-bold tracking-tight text-slate-900\" data-kid=\"115\">Archivo de Documentos</h2>\n        <div class=\"mt-6 rounded-3xl bg-slate-50 p-6\" data-kid=\"116\">\n          <div class=\"space-y-3\" data-kid=\"117\">\n            <div class=\"flex items-center justify-between rounded-full bg-white px-6 py-3 shadow-sm transition-colors hover:bg-teal-50\" data-kid=\"118\">\n              <div class=\"flex items-center gap-4\" data-kid=\"119\">\n                <i class=\"ti ti-file-text text-xl text-teal-600\" data-kid=\"120\"></i>\n                <span class=\"font-outfit text-sm font-medium text-slate-700\" data-kid=\"121\">Boletín Oficial Municipal No. 45</span>\n              </div>\n              <button class=\"text-emerald-600 hover:text-emerald-700\" data-kid=\"122\">\n                <i class=\"ti ti-download-cloud text-xl\" data-kid=\"123\"></i>\n              </button>\n            </div>\n            <div class=\"flex items-center justify-between rounded-full bg-white px-6 py-3 shadow-sm transition-colors hover:bg-teal-50\" data-kid=\"124\">\n              <div class=\"flex items-center gap-4\" data-kid=\"125\">\n                <i class=\"ti ti-file-text text-xl text-teal-600\" data-kid=\"126\"></i>\n                <span class=\"font-outfit text-sm font-medium text-slate-700\" data-kid=\"127\">Pliegos de Licitación: Alumbrado Público</span>\n              </div>\n              <button class=\"text-emerald-600 hover:text-emerald-700\" data-kid=\"128\">\n                <i class=\"ti ti-download-cloud text-xl\" data-kid=\"129\"></i>\n              </button>\n            </div>\n            <div class=\"flex items-center justify-between rounded-full bg-white px-6 py-3 shadow-sm transition-colors hover:bg-teal-50\" data-kid=\"130\">\n              <div class=\"flex items-center gap-4\" data-kid=\"131\">\n                <i class=\"ti ti-file-text text-xl text-teal-600\" data-kid=\"132\"></i>\n                <span class=\"font-outfit text-sm font-medium text-slate-700\" data-kid=\"133\">Ordenanza Fiscal Ejercicio 2024</span>\n              </div>\n              <button class=\"text-emerald-600 hover:text-emerald-700\" data-kid=\"134\">\n                <i class=\"ti ti-download-cloud text-xl\" data-kid=\"135\"></i>\n              </button>\n            </div>\n          </div>\n        </div>\n      </section>\n    </div>\n  </main>\n\n  \n  <footer class=\"border-t border-slate-100 bg-white py-12\" data-kid=\"136\">\n    <div class=\"mx-auto flex max-w-7xl flex-col items-center justify-between px-4 lg:flex-row\" data-kid=\"137\">\n      <div class=\"flex items-center gap-4\" data-kid=\"138\">\n        <img src=\"/api/local/images/public/images/institution/institution-logo.png\" alt=\"Escudo Municipal\" class=\"h-10 w-10 opacity-60 grayscale\" onerror=\"this.src='https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/shield-comb.svg'; this.style.filter='grayscale(100%) opacity(60%)';\" data-kid=\"139\">\n        <div class=\"flex flex-col\" data-kid=\"140\">\n          <span class=\"font-outfit text-sm font-bold text-slate-500\" data-kid=\"141\">© 2024 MUNICIPALIDAD</span>\n          <span class=\"text-xs text-slate-400\" data-kid=\"142\">Portal de Transparencia y Servicios</span>\n        </div>\n      </div>\n      <div class=\"mt-8 flex gap-8 lg:mt-0\" data-kid=\"143\">\n        <a href=\"#\" class=\"text-sm font-medium text-slate-500 hover:text-teal-700\" data-kid=\"144\">Términos y Condiciones</a>\n        <a href=\"#\" class=\"text-sm font-medium text-slate-500 hover:text-teal-700\" data-kid=\"145\">Privacidad</a>\n        <a href=\"#\" class=\"text-sm font-medium text-slate-500 hover:text-teal-700\" data-kid=\"146\">Contacto</a>\n      </div>\n      <div class=\"mt-8 flex gap-4 lg:mt-0 text-slate-400\" data-kid=\"147\">\n        <i class=\"ti ti-brand-facebook text-xl hover:text-teal-700\" data-kid=\"148\"></i>\n        <i class=\"ti ti-brand-x text-xl hover:text-teal-700\" data-kid=\"149\"></i>\n        <i class=\"ti ti-brand-instagram text-xl hover:text-teal-700\" data-kid=\"150\"></i>\n      </div>\n    </div>\n  </footer>\n</div>",
