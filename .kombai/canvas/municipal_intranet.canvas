      "html": "<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\" data-kid=\"0\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin data-kid=\"1\">\n<link href=\"https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600;700&display=swap\" rel=\"stylesheet\" data-kid=\"2\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"3\">\n\n<style data-kid=\"4\">\n  body {\n    font-family: 'Public Sans', sans-serif;\n    background-color: #F3F4F6;\n    color: #1F2937;\n    margin: 0;\n  }\n</style>\n\n<div class=\"min-h-screen\" data-kid=\"5\">\n  \n  <header class=\"border-b-4 border-[#2563EB]\" data-kid=\"6\">\n    \n    <div class=\"bg-[#064E3B] text-white py-2 px-6 flex justify-between items-center\" data-kid=\"7\">\n      <span class=\"text-sm font-semibold uppercase tracking-wider\" data-kid=\"8\">Portal Institucional</span>\n      <button class=\"border-2 border-white px-4 py-1 rounded-sm text-xs font-bold hover:bg-white hover:text-[#064E3B] transition-colors\" data-kid=\"9\">\n        Acceso interno\n      </button>\n    </div>\n    \n    <div class=\"bg-white py-4 px-6 flex items-center justify-between shadow-sm\" data-kid=\"10\">\n      <div class=\"flex items-center gap-4\" data-kid=\"11\">\n        <div class=\"bg-[#1F2937] p-2 rounded-sm\" data-kid=\"12\">\n          \n          <div class=\"w-10 h-10 border-2 border-white flex items-center justify-center font-bold text-white text-xl\" data-kid=\"13\">M</div>\n        </div>\n        <div class=\"leading-tight\" data-kid=\"14\">\n          <h1 class=\"text-xl font-bold uppercase tracking-tight\" data-kid=\"15\">Municipalidad</h1>\n          <p class=\"text-sm text-gray-600 font-medium\" data-kid=\"16\">Gestión Ciudadana</p>\n        </div>\n      </div>\n      \n      <div class=\"flex items-center gap-8\" data-kid=\"17\">\n        <nav class=\"hidden md:flex gap-6\" data-kid=\"18\">\n          <a href=\"#\" class=\"font-bold text-[#1F2937] hover:text-[#2563EB]\" data-kid=\"19\">Inicio</a>\n          <a href=\"#\" class=\"font-bold text-[#1F2937] hover:text-[#2563EB]\" data-kid=\"20\">Trámites</a>\n          <a href=\"#\" class=\"font-bold text-[#1F2937] hover:text-[#2563EB]\" data-kid=\"21\">Noticias</a>\n          <a href=\"#\" class=\"font-bold text-[#1F2937] hover:text-[#2563EB]\" data-kid=\"22\">Participación</a>\n          <a href=\"#\" class=\"font-bold text-[#1F2937] hover:text-[#2563EB]\" data-kid=\"23\">Transparencia</a>\n        </nav>\n        \n        <div class=\"relative group\" data-kid=\"24\">\n          <input type=\"text\" placeholder=\"Buscar servicios...\" class=\"bg-gray-100 border-b-2 border-gray-300 px-4 py-2 pr-10 focus:outline-hidden focus:border-[#2563EB] w-64 transition-all\" data-kid=\"25\">\n          <i class=\"ti ti-search absolute right-3 top-1/2 -translate-y-1/2 text-gray-500\" data-kid=\"26\"></i>\n        </div>\n      </div>\n    </div>\n  </header>\n\n  <main class=\"max-w-7xl mx-auto px-6 py-8 space-y-12\" data-kid=\"27\">\n    \n    <section class=\"relative bg-black h-[450px] rounded-sm overflow-hidden shadow-xl\" data-kid=\"28\">\n      <img src=\"https://images.unsplash.com/photo-1771344152621-8a67bce53695?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NTAwNDR8MHwxfHNlYXJjaHwxfHxjaXRpemVucyUyMGludGVyYWN0aW5nJTIwaW4lMjBhJTIwc3VubnklMjBwdWJsaWMlMjBwYXJrfGVufDB8fHx8MTc4Mjg3Njg4NXww&ixlib=rb-4.1.0&q=85&auto=format&w=1280&q=80&fit=crop\" alt=\"Ciudadanos en un parque público\" class=\"absolute inset-0 w-full h-full object-cover opacity-70\" decoding=\"async\" loading=\"lazy\" data-kid=\"29\">\n      \n      <div class=\"absolute inset-0 bg-linear-to-r from-black/80 via-black/40 to-transparent\" data-kid=\"30\"></div>\n      \n      <div class=\"relative h-full flex flex-col justify-center px-12 max-w-2xl text-white\" data-kid=\"31\">\n        <h2 class=\"text-5xl font-extrabold leading-tight mb-4\" data-kid=\"32\">Tu Municipio Trabaja para Ti</h2>\n        <p class=\"text-lg text-gray-200 mb-8 font-medium\" data-kid=\"33\">Conoce los avances, proyectos y servicios disponibles en tu comunidad.</p>\n        <button class=\"bg-[#2563EB] text-white px-8 py-3 font-bold text-lg rounded-sm hover:bg-blue-700 w-fit transition-transform active:scale-95\" data-kid=\"34\">\n          Ver Proyectos\n        </button>\n      </div>\n\n      \n      <div class=\"absolute bottom-6 right-6 flex items-center gap-4\" data-kid=\"35\">\n        <div class=\"flex gap-2\" data-kid=\"36\">\n          <span class=\"w-3 h-3 bg-white rounded-xs\" data-kid=\"37\"></span>\n          <span class=\"w-3 h-3 bg-white/40 rounded-xs\" data-kid=\"38\"></span>\n          <span class=\"w-3 h-3 bg-white/40 rounded-xs\" data-kid=\"39\"></span>\n        </div>\n        <div class=\"flex bg-white rounded-sm overflow-hidden\" data-kid=\"40\">\n          <button class=\"p-3 text-gray-800 hover:bg-gray-100 border-r border-gray-200 transition-colors\" data-kid=\"41\">\n            <i class=\"ti ti-chevron-left text-xl\" data-kid=\"42\"></i>\n          </button>\n          <button class=\"p-3 text-gray-800 hover:bg-gray-100 transition-colors\" data-kid=\"43\">\n            <i class=\"ti ti-chevron-right text-xl\" data-kid=\"44\"></i>\n          </button>\n        </div>\n      </div>\n    </section>\n\n    \n    <section data-kid=\"45\">\n      <h3 class=\"text-2xl font-bold mb-6 flex items-center gap-3\" data-kid=\"46\">\n        <span class=\"w-2 h-8 bg-[#166534]\" data-kid=\"47\"></span>\n        Servicios Frecuentes\n      </h3>\n      <div class=\"grid grid-cols-2 md:grid-cols-5 gap-4\" data-kid=\"48\">\n        \n        <a href=\"#\" class=\"bg-[#166534] text-white p-6 rounded-[16px] flex flex-col justify-between h-32 hover:opacity-90 transition-all group\" data-kid=\"49\">\n          <span class=\"text-lg font-bold leading-tight\" data-kid=\"50\">Portal Tributario</span>\n          <i class=\"ti ti-arrow-right self-end group-hover:translate-x-1 transition-transform\" data-kid=\"51\"></i>\n        </a>\n        <a href=\"#\" class=\"bg-[#2563EB] text-white p-6 rounded-[16px] flex flex-col justify-between h-32 hover:opacity-90 transition-all group\" data-kid=\"52\">\n          <span class=\"text-lg font-bold leading-tight\" data-kid=\"53\">Bolsa de Empleo</span>\n          <i class=\"ti ti-arrow-right self-end group-hover:translate-x-1 transition-transform\" data-kid=\"54\"></i>\n        </a>\n        <a href=\"#\" class=\"bg-[#166534] text-white p-6 rounded-[16px] flex flex-col justify-between h-32 hover:opacity-90 transition-all group\" data-kid=\"55\">\n          <span class=\"text-lg font-bold leading-tight\" data-kid=\"56\">Licencias de Conducir</span>\n          <i class=\"ti ti-arrow-right self-end group-hover:translate-x-1 transition-transform\" data-kid=\"57\"></i>\n        </a>\n        <a href=\"#\" class=\"bg-[#2563EB] text-white p-6 rounded-[16px] flex flex-col justify-between h-32 hover:opacity-90 transition-all group\" data-kid=\"58\">\n          <span class=\"text-lg font-bold leading-tight\" data-kid=\"59\">Registro Civil</span>\n          <i class=\"ti ti-arrow-right self-end group-hover:translate-x-1 transition-transform\" data-kid=\"60\"></i>\n        </a>\n        <a href=\"#\" class=\"bg-[#166534] text-white p-6 rounded-[16px] flex flex-col justify-between h-32 hover:opacity-90 transition-all group\" data-kid=\"61\">\n          <span class=\"text-lg font-bold leading-tight\" data-kid=\"62\">Agenda Cultural</span>\n          <i class=\"ti ti-arrow-right self-end group-hover:translate-x-1 transition-transform\" data-kid=\"63\"></i>\n        </a>\n      </div>\n    </section>\n\n    \n    <section data-kid=\"64\">\n      <h3 class=\"text-2xl font-bold mb-6 flex items-center gap-3\" data-kid=\"65\">\n        <span class=\"w-2 h-8 bg-[#2563EB]\" data-kid=\"66\"></span>\n        Últimos Comunicados\n      </h3>\n      <div class=\"grid grid-cols-1 md:grid-cols-3 gap-6\" data-kid=\"67\">\n        \n        <div class=\"bg-white rounded-sm border border-gray-200 overflow-hidden hover:shadow-md transition-shadow\" data-kid=\"68\">\n          <img src=\"https://images.unsplash.com/photo-1706712637075-f47fb47548f2?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NTAwNDR8MHwxfHNlYXJjaHwxfHxuZXclMjByb2FkJTIwY29uc3RydWN0aW9uJTIwYXNwaGFsdHxlbnwwfHx8fDE3ODI4NzY4ODV8MA&ixlib=rb-4.1.0&q=85&auto=format&w=600&q=80&fit=crop\" alt=\"Pavimentación de vías\" class=\"w-full h-48 object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"69\">\n          <div class=\"p-6\" data-kid=\"70\">\n            <span class=\"text-xs font-bold text-[#166534] uppercase tracking-widest mb-2 block\" data-kid=\"71\">Infraestructura</span>\n            <h4 class=\"text-xl font-bold mb-3 leading-snug\" data-kid=\"72\">Avance en la pavimentación de la Avenida Principal</h4>\n            <p class=\"text-gray-600 text-sm line-clamp-2\" data-kid=\"73\">Las obras registran un 75% de avance y se espera la entrega total para el próximo mes de agosto...</p>\n          </div>\n        </div>\n        \n        <div class=\"bg-white rounded-sm border border-gray-200 overflow-hidden hover:shadow-md transition-shadow\" data-kid=\"74\">\n          <div class=\"w-full h-48 bg-gray-200 flex items-center justify-center\" data-kid=\"75\">\n            <i class=\"ti ti-camera text-4xl text-gray-400\" data-kid=\"76\"></i>\n          </div>\n          <div class=\"p-6\" data-kid=\"77\">\n            <span class=\"text-xs font-bold text-[#2563EB] uppercase tracking-widest mb-2 block\" data-kid=\"78\">Comunidad</span>\n            <h4 class=\"text-xl font-bold mb-3 leading-snug\" data-kid=\"79\">Gran jornada de vacunación este fin de semana</h4>\n            <p class=\"text-gray-600 text-sm line-clamp-2\" data-kid=\"80\">Invitamos a todas las familias a participar en la jornada nacional que se llevará a cabo en el parque central...</p>\n          </div>\n        </div>\n        \n        <div class=\"bg-white rounded-sm border border-gray-200 overflow-hidden hover:shadow-md transition-shadow\" data-kid=\"81\">\n          <div class=\"w-full h-48 bg-gray-200 flex items-center justify-center\" data-kid=\"82\">\n            <i class=\"ti ti-news text-4xl text-gray-400\" data-kid=\"83\"></i>\n          </div>\n          <div class=\"p-6\" data-kid=\"84\">\n            <span class=\"text-xs font-bold text-[#166534] uppercase tracking-widest mb-2 block\" data-kid=\"85\">Economía</span>\n            <h4 class=\"text-xl font-bold mb-3 leading-snug\" data-kid=\"86\">Nuevos incentivos para emprendedores locales</h4>\n            <p class=\"text-gray-600 text-sm line-clamp-2\" data-kid=\"87\">El concejo aprobó una serie de alivios tributarios para quienes inicien actividades comerciales durante el 2024...</p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <div class=\"grid grid-cols-1 md:grid-cols-2 gap-12\" data-kid=\"88\">\n      \n      <section data-kid=\"89\">\n        <h3 class=\"text-2xl font-bold mb-6 flex items-center gap-3\" data-kid=\"90\">\n          <span class=\"w-2 h-8 bg-[#166534]\" data-kid=\"91\"></span>\n          Agenda de Eventos\n        </h3>\n        <div class=\"relative pl-8 space-y-8\" data-kid=\"92\">\n          <div class=\"absolute left-[7px] top-2 bottom-2 w-0.5 bg-gray-300\" data-kid=\"93\"></div>\n          \n          <div class=\"relative\" data-kid=\"94\">\n            <div class=\"absolute -left-8 top-1.5 w-4 h-4 rounded-full border-4 border-[#166534] bg-white\" data-kid=\"95\"></div>\n            <div class=\"bg-white p-4 border border-gray-200 rounded-sm\" data-kid=\"96\">\n              <span class=\"text-sm font-bold text-[#166534]\" data-kid=\"97\">15 de Julio - 10:00 AM</span>\n              <h5 class=\"font-bold text-lg\" data-kid=\"98\">Inauguración Centro Deportivo</h5>\n              <p class=\"text-sm text-gray-600\" data-kid=\"99\">Sector Sur, Barrio San José</p>\n            </div>\n          </div>\n          \n          <div class=\"relative\" data-kid=\"100\">\n            <div class=\"absolute -left-8 top-1.5 w-4 h-4 rounded-full border-4 border-gray-300 bg-white\" data-kid=\"101\"></div>\n            <div class=\"bg-white p-4 border border-gray-200 rounded-sm\" data-kid=\"102\">\n              <span class=\"text-sm font-bold text-gray-500\" data-kid=\"103\">20 de Julio - 06:00 PM</span>\n              <h5 class=\"font-bold text-lg\" data-kid=\"104\">Concierto de Verano</h5>\n              <p class=\"text-sm text-gray-600\" data-kid=\"105\">Plaza de Armas</p>\n            </div>\n          </div>\n          \n          <div class=\"relative\" data-kid=\"106\">\n            <div class=\"absolute -left-8 top-1.5 w-4 h-4 rounded-full border-4 border-gray-300 bg-white\" data-kid=\"107\"></div>\n            <div class=\"bg-white p-4 border border-gray-200 rounded-sm\" data-kid=\"108\">\n              <span class=\"text-sm font-bold text-gray-500\" data-kid=\"109\">22 de Julio - 09:00 AM</span>\n              <h5 class=\"font-bold text-lg\" data-kid=\"110\">Feria de Emprendimiento</h5>\n              <p class=\"text-sm text-gray-600\" data-kid=\"111\">Centro de Convenciones</p>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      \n      <section data-kid=\"112\">\n        <h3 class=\"text-2xl font-bold mb-6 flex items-center gap-3\" data-kid=\"113\">\n          <span class=\"w-2 h-8 bg-[#2563EB]\" data-kid=\"114\"></span>\n          Publicaciones y Documentos\n        </h3>\n        <div class=\"bg-white border border-gray-200 rounded-sm divide-y divide-gray-100 shadow-xs\" data-kid=\"115\">\n          <a href=\"#\" class=\"flex items-center justify-between p-4 hover:bg-gray-50 transition-colors\" data-kid=\"116\">\n            <div class=\"flex items-center gap-3\" data-kid=\"117\">\n              <i class=\"ti ti-file-text text-2xl text-[#2563EB]\" data-kid=\"118\"></i>\n              <span class=\"font-semibold\" data-kid=\"119\">Resoluciones de Alcaldía 2024</span>\n            </div>\n            <i class=\"ti ti-download text-gray-400\" data-kid=\"120\"></i>\n          </a>\n          <a href=\"#\" class=\"flex items-center justify-between p-4 hover:bg-gray-50 transition-colors\" data-kid=\"121\">\n            <div class=\"flex items-center gap-3\" data-kid=\"122\">\n              <i class=\"ti ti-file-text text-2xl text-[#2563EB]\" data-kid=\"123\"></i>\n              <span class=\"font-semibold\" data-kid=\"124\">Ordenanza de Convivencia Ciudadana</span>\n            </div>\n            <i class=\"ti ti-download text-gray-400\" data-kid=\"125\"></i>\n          </a>\n          <a href=\"#\" class=\"flex items-center justify-between p-4 hover:bg-gray-50 transition-colors\" data-kid=\"126\">\n            <div class=\"flex items-center gap-3\" data-kid=\"127\">\n              <i class=\"ti ti-file-text text-2xl text-[#2563EB]\" data-kid=\"128\"></i>\n              <span class=\"font-semibold\" data-kid=\"129\">Pliegos de Licitación Pública</span>\n            </div>\n            <i class=\"ti ti-download text-gray-400\" data-kid=\"130\"></i>\n          </a>\n          <a href=\"#\" class=\"flex items-center justify-between p-4 hover:bg-gray-50 transition-colors\" data-kid=\"131\">\n            <div class=\"flex items-center gap-3\" data-kid=\"132\">\n              <i class=\"ti ti-file-text text-2xl text-[#2563EB]\" data-kid=\"133\"></i>\n              <span class=\"font-semibold\" data-kid=\"134\">Plan de Desarrollo Comunal</span>\n            </div>\n            <i class=\"ti ti-download text-gray-400\" data-kid=\"135\"></i>\n          </a>\n          <a href=\"#\" class=\"flex items-center justify-between p-4 hover:bg-gray-50 transition-colors\" data-kid=\"136\">\n            <div class=\"flex items-center gap-3\" data-kid=\"137\">\n              <i class=\"ti ti-file-text text-2xl text-[#2563EB]\" data-kid=\"138\"></i>\n              <span class=\"font-semibold\" data-kid=\"139\">Boletín Oficial No. 45</span>\n            </div>\n            <i class=\"ti ti-download text-gray-400\" data-kid=\"140\"></i>\n          </a>\n        </div>\n        <button class=\"mt-6 text-[#2563EB] font-bold flex items-center gap-2 hover:underline\" data-kid=\"141\">\n          Ver todos los documentos <i class=\"ti ti-arrow-right\" data-kid=\"142\"></i>\n        </button>\n      </section>\n    </div>\n  </main>\n\n  \n  <footer class=\"bg-[#1F2937] text-white py-12 px-6 mt-16\" data-kid=\"143\">\n    <div class=\"max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-8\" data-kid=\"144\">\n      <div class=\"col-span-1 md:col-span-2\" data-kid=\"145\">\n        <div class=\"flex items-center gap-4 mb-6\" data-kid=\"146\">\n          <div class=\"bg-white p-2 rounded-sm text-[#1F2937]\" data-kid=\"147\">\n            <div class=\"w-8 h-8 border-2 border-[#1F2937] flex items-center justify-center font-bold text-xl\" data-kid=\"148\">M</div>\n          </div>\n          <h2 class=\"text-xl font-bold uppercase tracking-tight\" data-kid=\"149\">Municipalidad</h2>\n        </div>\n        <p class=\"text-gray-400 max-w-md\" data-kid=\"150\">Plataforma oficial de servicios y transparencia municipal. Trabajamos por una ciudad más integrada y moderna para todos nuestros vecinos.</p>\n      </div>\n      <div data-kid=\"151\">\n        <h4 class=\"font-bold mb-4 uppercase text-xs tracking-widest text-gray-500\" data-kid=\"152\">Contacto</h4>\n        <ul class=\"space-y-2 text-sm text-gray-300\" data-kid=\"153\">\n          <li data-kid=\"154\">Av. Libertad 123, Centro</li>\n          <li data-kid=\"155\">Tel: (555) 0123-4567</li>\n          <li data-kid=\"156\">contacto@municipalidad.gov</li>\n        </ul>\n      </div>\n      <div data-kid=\"157\">\n        <h4 class=\"font-bold mb-4 uppercase text-xs tracking-widest text-gray-500\" data-kid=\"158\">Enlaces</h4>\n        <ul class=\"space-y-2 text-sm text-gray-300\" data-kid=\"159\">\n          <li data-kid=\"160\"><a href=\"#\" class=\"hover:text-white\" data-kid=\"161\">Transparencia Activa</a></li>\n          <li data-kid=\"162\"><a href=\"#\" class=\"hover:text-white\" data-kid=\"163\">Portal de Datos Abiertos</a></li>\n          <li data-kid=\"164\"><a href=\"#\" class=\"hover:text-white\" data-kid=\"165\">Defensoría del Pueblo</a></li>\n        </ul>\n      </div>\n    </div>\n    <div class=\"max-w-7xl mx-auto border-t border-gray-700 mt-12 pt-8 text-center text-xs text-gray-500\" data-kid=\"166\">\n      &copy; 2024 Municipalidad - Todos los derechos reservados.\n    </div>\n  </footer>\n</div>",
