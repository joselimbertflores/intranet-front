      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Merriweather:wght@400;700&family=Inter:wght@400;500;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  body {\n    font-family: 'Inter', sans-serif;\n    color: #1F2937;\n    margin: 0;\n  }\n\n  .font-heading {\n    font-family: 'Merriweather', serif;\n  }\n\n  .bg-alabaster {\n    background-color: #FAFAFA;\n  }\n\n  .text-navy {\n    color: #1E3A8A;\n  }\n\n  .bg-navy {\n    background-color: #1E3A8A;\n  }\n\n  .bg-aqua {\n    background-color: #20B2AA;\n  }\n\n  .border-soft {\n    border-color: #E5E7EB;\n  }\n</style>\n\n<div class=\"min-h-screen bg-alabaster\" data-kid=\"1\">\n  \n  <div class=\"bg-white border-b border-soft py-2\" data-kid=\"2\">\n    <div class=\"max-w-[1200px] mx-auto px-4 flex justify-end items-center\" data-kid=\"3\">\n      <button class=\"bg-navy text-white text-xs px-4 py-1.5 rounded-full font-medium hover:bg-opacity-90 transition-all\" data-kid=\"4\">\n        Acceso interno\n      </button>\n    </div>\n  </div>\n\n  \n  <header class=\"bg-white border-b border-soft sticky top-0 z-50\" data-kid=\"5\">\n    <div class=\"max-w-[1200px] mx-auto px-4 h-20 flex items-center justify-between\" data-kid=\"6\">\n      \n      <div class=\"flex items-center gap-3\" data-kid=\"7\">\n        <img src=\"/api/local/images/public/images/institution/institution-logo.png\" alt=\"Logo Municipal\" class=\"h-14 w-auto object-contain\" decoding=\"async\" loading=\"lazy\" data-kid=\"8\">\n        <div class=\"hidden md:block\" data-kid=\"9\">\n          <h1 class=\"font-heading text-lg font-bold text-navy leading-tight uppercase\" data-kid=\"10\">Gobierno Municipal</h1>\n          <p class=\"text-[10px] text-gray-500 uppercase tracking-widest\" data-kid=\"11\">Portal Institucional</p>\n        </div>\n      </div>\n\n      \n      <nav class=\"hidden lg:flex items-center gap-8\" data-kid=\"12\">\n        <a href=\"#\" class=\"text-navy font-semibold text-sm hover:text-aqua transition-colors\" data-kid=\"13\">Inicio</a>\n        <a href=\"#\" class=\"text-gray-600 font-medium text-sm hover:text-navy transition-colors\" data-kid=\"14\">El Municipio</a>\n        <a href=\"#\" class=\"text-gray-600 font-medium text-sm hover:text-navy transition-colors\" data-kid=\"15\">Servicios</a>\n        <a href=\"#\" class=\"text-gray-600 font-medium text-sm hover:text-navy transition-colors\" data-kid=\"16\">Contacto</a>\n      </nav>\n\n      \n      <div class=\"relative w-64\" data-kid=\"17\">\n        <input type=\"text\" placeholder=\"Buscar servicios...\" class=\"w-full bg-gray-100 border-none rounded-lg py-2 pl-4 pr-10 text-sm focus:ring-2 focus:ring-navy focus:bg-white transition-all outline-hidden\" data-kid=\"18\">\n        <i class=\"ti ti-search absolute right-3 top-1/2 -translate-y-1/2 text-gray-400\" data-kid=\"19\"></i>\n      </div>\n    </div>\n  </header>\n\n  <main class=\"max-w-[1200px] mx-auto px-4 py-8 space-y-12\" data-kid=\"20\">\n    \n    <section class=\"relative h-[400px] rounded-2xl overflow-hidden shadow-sm group\" data-kid=\"21\">\n      <img src=\"https://images.unsplash.com/photo-1776455971672-2aa3568dcb2c?auto=format&w=1200&q=80&fit=crop\" alt=\"Edificio Municipal - Cristina Anne Costello on Unsplash\" class=\"absolute inset-0 w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"22\">\n      \n      <div class=\"absolute inset-0 bg-linear-to-t from-black/80 via-black/40 to-transparent\" data-kid=\"23\"></div>\n      \n      \n      <div class=\"relative h-full flex flex-col items-center justify-center text-center px-6 space-y-4\" data-kid=\"24\">\n        <h2 class=\"font-heading text-4xl md:text-5xl text-white font-bold max-w-2xl\" data-kid=\"25\">Bienvenidos al Portal Municipal</h2>\n        <p class=\"text-gray-200 text-lg md:text-xl max-w-xl\" data-kid=\"26\">Transparencia y servicios al alcance de todos para una mejor comunidad.</p>\n        <button class=\"bg-aqua text-white px-8 py-3 rounded-lg font-bold text-sm shadow-lg hover:brightness-110 hover:-translate-y-0.5 transition-all\" data-kid=\"27\">\n          Explorar Servicios\n        </button>\n      </div>\n\n      \n      <button class=\"absolute left-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/10 backdrop-blur-md text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"28\">\n        <i class=\"ti ti-chevron-left text-xl\" data-kid=\"29\"></i>\n      </button>\n      <button class=\"absolute right-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/10 backdrop-blur-md text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"30\">\n        <i class=\"ti ti-chevron-right text-xl\" data-kid=\"31\"></i>\n      </button>\n\n      \n      <div class=\"absolute bottom-6 left-1/2 -translate-x-1/2 flex gap-2\" data-kid=\"32\">\n        <span class=\"w-2.5 h-2.5 rounded-full bg-white\" data-kid=\"33\"></span>\n        <span class=\"w-2.5 h-2.5 rounded-full bg-white/40\" data-kid=\"34\"></span>\n        <span class=\"w-2.5 h-2.5 rounded-full bg-white/40\" data-kid=\"35\"></span>\n      </div>\n    </section>\n\n    \n    <section data-kid=\"36\">\n      <div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6\" data-kid=\"37\">\n        <a href=\"#\" class=\"bg-white p-8 rounded-xl border border-soft shadow-xs hover:shadow-md hover:-translate-y-1 transition-all flex flex-col items-center text-center space-y-4\" data-kid=\"38\">\n          <div class=\"w-16 h-16 rounded-full bg-alabaster flex items-center justify-center text-navy\" data-kid=\"39\">\n            <i class=\"ti ti-credit-card text-3xl\" data-kid=\"40\"></i>\n          </div>\n          <h3 class=\"font-bold text-navy\" data-kid=\"41\">Trámites y Pagos</h3>\n        </a>\n        <a href=\"#\" class=\"bg-white p-8 rounded-xl border border-soft shadow-xs hover:shadow-md hover:-translate-y-1 transition-all flex flex-col items-center text-center space-y-4\" data-kid=\"42\">\n          <div class=\"w-16 h-16 rounded-full bg-alabaster flex items-center justify-center text-navy\" data-kid=\"43\">\n            <i class=\"ti ti-eye text-3xl\" data-kid=\"44\"></i>\n          </div>\n          <h3 class=\"font-bold text-navy\" data-kid=\"45\">Transparencia</h3>\n        </a>\n        <a href=\"#\" class=\"bg-white p-8 rounded-xl border border-soft shadow-xs hover:shadow-md hover:-translate-y-1 transition-all flex flex-col items-center text-center space-y-4\" data-kid=\"46\">\n          <div class=\"w-16 h-16 rounded-full bg-alabaster flex items-center justify-center text-navy\" data-kid=\"47\">\n            <i class=\"ti ti-users text-3xl\" data-kid=\"48\"></i>\n          </div>\n          <h3 class=\"font-bold text-navy\" data-kid=\"49\">Atención Ciudadana</h3>\n        </a>\n        <a href=\"#\" class=\"bg-white p-8 rounded-xl border border-soft shadow-xs hover:shadow-md hover:-translate-y-1 transition-all flex flex-col items-center text-center space-y-4\" data-kid=\"50\">\n          <div class=\"w-16 h-16 rounded-full bg-alabaster flex items-center justify-center text-navy\" data-kid=\"51\">\n            <i class=\"ti ti-hammer text-3xl\" data-kid=\"52\"></i>\n          </div>\n          <h3 class=\"font-bold text-navy\" data-kid=\"53\">Obras Públicas</h3>\n        </a>\n      </div>\n    </section>\n\n    \n    <section class=\"grid grid-cols-1 lg:grid-cols-5 gap-12\" data-kid=\"54\">\n      \n      <div class=\"lg:col-span-3 space-y-6\" data-kid=\"55\">\n        <div class=\"flex justify-between items-end border-b border-soft pb-2\" data-kid=\"56\">\n          <h2 class=\"font-heading text-2xl font-bold text-navy\" data-kid=\"57\">Noticias Municipales</h2>\n          <a href=\"#\" class=\"text-aqua text-sm font-semibold hover:underline\" data-kid=\"58\">Ver todas</a>\n        </div>\n        \n        <div class=\"space-y-8\" data-kid=\"59\">\n          <article class=\"flex gap-6 items-start group\" data-kid=\"60\">\n            <img src=\"https://images.unsplash.com/photo-1771340591273-b509bd520400?auto=format&w=400&q=80&fit=crop\" alt=\"Alcaldesa en evento - Olek Buzunov on Unsplash\" class=\"w-40 h-40 object-cover rounded-lg\" decoding=\"async\" loading=\"lazy\" data-kid=\"61\">\n            <div class=\"space-y-2\" data-kid=\"62\">\n              <span class=\"text-xs font-bold text-aqua uppercase tracking-wider\" data-kid=\"63\">Gestión</span>\n              <h3 class=\"font-heading text-xl font-bold leading-tight group-hover:text-navy transition-colors\" data-kid=\"64\">Nueva infraestructura vial inaugurada en el sector norte</h3>\n              <p class=\"text-sm text-gray-600 line-clamp-2\" data-kid=\"65\">El Gobierno Municipal entregó hoy las obras de pavimentación que beneficiarán a más de 5,000 familias...</p>\n              <time class=\"text-[11px] text-gray-400 block\" data-kid=\"66\">15 de Octubre, 2024</time>\n            </div>\n          </article>\n\n          <article class=\"flex gap-6 items-start group\" data-kid=\"67\">\n            <img src=\"https://images.unsplash.com/photo-1771340591221-73d9828e09c7?auto=format&w=400&q=80&fit=crop\" alt=\"Evento municipal - Olek Buzunov on Unsplash\" class=\"w-40 h-40 object-cover rounded-lg\" decoding=\"async\" loading=\"lazy\" data-kid=\"68\">\n            <div class=\"space-y-2\" data-kid=\"69\">\n              <span class=\"text-xs font-bold text-aqua uppercase tracking-wider\" data-kid=\"70\">Social</span>\n              <h3 class=\"font-heading text-xl font-bold leading-tight group-hover:text-navy transition-colors\" data-kid=\"71\">Lanzamiento del programa de salud comunitaria preventiva</h3>\n              <p class=\"text-sm text-gray-600 line-clamp-2\" data-kid=\"72\">Se habilitarán puntos de atención en todas las plazas principales durante el próximo mes...</p>\n              <time class=\"text-[11px] text-gray-400 block\" data-kid=\"73\">12 de Octubre, 2024</time>\n            </div>\n          </article>\n        </div>\n      </div>\n\n      \n      <div class=\"lg:col-span-2 space-y-6\" data-kid=\"74\">\n        <div class=\"flex justify-between items-end border-b border-soft pb-2\" data-kid=\"75\">\n          <h2 class=\"font-heading text-2xl font-bold text-navy\" data-kid=\"76\">Agenda de Eventos</h2>\n          <a href=\"#\" class=\"text-aqua text-sm font-semibold hover:underline\" data-kid=\"77\">Ver calendario</a>\n        </div>\n\n        <div class=\"space-y-6\" data-kid=\"78\">\n          <div class=\"flex gap-4 items-center\" data-kid=\"79\">\n            <div class=\"w-16 h-16 flex flex-col items-center justify-center bg-navy text-white rounded-lg shrink-0\" data-kid=\"80\">\n              <span class=\"text-lg font-bold leading-none\" data-kid=\"81\">20</span>\n              <span class=\"text-[10px] font-medium uppercase tracking-tighter\" data-kid=\"82\">OCT</span>\n            </div>\n            <div data-kid=\"83\">\n              <h4 class=\"font-bold text-gray-800 leading-tight\" data-kid=\"84\">Sesión Ordinaria de Concejo Municipal</h4>\n              <p class=\"text-xs text-gray-500 mt-1\" data-kid=\"85\"><i class=\"ti ti-map-pin mr-1\" data-kid=\"86\"></i>Salón Consistorial, 09:00 AM</p>\n            </div>\n          </div>\n\n          <div class=\"flex gap-4 items-center\" data-kid=\"87\">\n            <div class=\"w-16 h-16 flex flex-col items-center justify-center bg-navy text-white rounded-lg shrink-0\" data-kid=\"88\">\n              <span class=\"text-lg font-bold leading-none\" data-kid=\"89\">24</span>\n              <span class=\"text-[10px] font-medium uppercase tracking-tighter\" data-kid=\"90\">OCT</span>\n            </div>\n            <div data-kid=\"91\">\n              <h4 class=\"font-bold text-gray-800 leading-tight\" data-kid=\"92\">Feria Gastronómica \"Sabores Locales\"</h4>\n              <p class=\"text-xs text-gray-500 mt-1\" data-kid=\"93\"><i class=\"ti ti-map-pin mr-1\" data-kid=\"94\"></i>Plaza de Armas, 11:00 AM</p>\n            </div>\n          </div>\n\n          <div class=\"flex gap-4 items-center\" data-kid=\"95\">\n            <div class=\"w-16 h-16 flex flex-col items-center justify-center bg-navy text-white rounded-lg shrink-0\" data-kid=\"96\">\n              <span class=\"text-lg font-bold leading-none\" data-kid=\"97\">28</span>\n              <span class=\"text-[10px] font-medium uppercase tracking-tighter\" data-kid=\"98\">OCT</span>\n            </div>\n            <div data-kid=\"99\">\n              <h4 class=\"font-bold text-gray-800 leading-tight\" data-kid=\"100\">Audiencia Pública Participativa 2024</h4>\n              <p class=\"text-xs text-gray-500 mt-1\" data-kid=\"101\"><i class=\"ti ti-map-pin mr-1\" data-kid=\"102\"></i>Auditorio Municipal, 17:00 PM</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"space-y-6\" data-kid=\"103\">\n      <div class=\"flex justify-between items-end border-b border-soft pb-2\" data-kid=\"104\">\n        <h2 class=\"font-heading text-2xl font-bold text-navy\" data-kid=\"105\">Documentos Recientes</h2>\n        <a href=\"#\" class=\"text-aqua text-sm font-semibold hover:underline\" data-kid=\"106\">Ver repositorio</a>\n      </div>\n\n      <div class=\"bg-white rounded-xl border border-soft overflow-hidden shadow-xs\" data-kid=\"107\">\n        <table class=\"w-full text-left border-collapse\" data-kid=\"108\">\n          <thead class=\"bg-alabaster border-b border-soft\" data-kid=\"109\">\n            <tr data-kid=\"110\">\n              <th class=\"px-6 py-4 text-xs font-bold text-gray-500 uppercase\" data-kid=\"111\">Nombre del Documento</th>\n              <th class=\"px-6 py-4 text-xs font-bold text-gray-500 uppercase\" data-kid=\"112\">Categoría</th>\n              <th class=\"px-6 py-4 text-xs font-bold text-gray-500 uppercase\" data-kid=\"113\">Fecha</th>\n              <th class=\"px-6 py-4 text-xs font-bold text-gray-500 uppercase text-right\" data-kid=\"114\">Acción</th>\n            </tr>\n          </thead>\n          <tbody class=\"divide-y divide-soft\" data-kid=\"115\">\n            <tr class=\"hover:bg-alabaster transition-colors group\" data-kid=\"116\">\n              <td class=\"px-6 py-4\" data-kid=\"117\">\n                <div class=\"flex items-center gap-3\" data-kid=\"118\">\n                  <i class=\"ti ti-file-text text-navy text-xl\" data-kid=\"119\"></i>\n                  <span class=\"text-sm font-medium text-gray-700\" data-kid=\"120\">Acta de Sesión Ordinaria No. 42-2024</span>\n                </div>\n              </td>\n              <td class=\"px-6 py-4\" data-kid=\"121\"><span class=\"px-2 py-1 bg-blue-50 text-blue-600 rounded text-[10px] font-bold uppercase\" data-kid=\"122\">Actas</span></td>\n              <td class=\"px-6 py-4 text-sm text-gray-500\" data-kid=\"123\">14/10/2024</td>\n              <td class=\"px-6 py-4 text-right\" data-kid=\"124\">\n                <button class=\"text-aqua hover:text-navy transition-colors\" data-kid=\"125\">\n                  <i class=\"ti ti-download text-xl\" data-kid=\"126\"></i>\n                </button>\n              </td>\n            </tr>\n            <tr class=\"hover:bg-alabaster transition-colors group\" data-kid=\"127\">\n              <td class=\"px-6 py-4\" data-kid=\"128\">\n                <div class=\"flex items-center gap-3\" data-kid=\"129\">\n                  <i class=\"ti ti-file-text text-navy text-xl\" data-kid=\"130\"></i>\n                  <span class=\"text-sm font-medium text-gray-700\" data-kid=\"131\">Resolución de Alcaldía No. 125-2024</span>\n                </div>\n              </td>\n              <td class=\"px-6 py-4\" data-kid=\"132\"><span class=\"px-2 py-1 bg-green-50 text-green-600 rounded text-[10px] font-bold uppercase\" data-kid=\"133\">Resoluciones</span></td>\n              <td class=\"px-6 py-4 text-sm text-gray-500\" data-kid=\"134\">11/10/2024</td>\n              <td class=\"px-6 py-4 text-right\" data-kid=\"135\">\n                <button class=\"text-aqua hover:text-navy transition-colors\" data-kid=\"136\">\n                  <i class=\"ti ti-download text-xl\" data-kid=\"137\"></i>\n                </button>\n              </td>\n            </tr>\n            <tr class=\"hover:bg-alabaster transition-colors group\" data-kid=\"138\">\n              <td class=\"px-6 py-4\" data-kid=\"139\">\n                <div class=\"flex items-center gap-3\" data-kid=\"140\">\n                  <i class=\"ti ti-file-text text-navy text-xl\" data-kid=\"141\"></i>\n                  <span class=\"text-sm font-medium text-gray-700\" data-kid=\"142\">Pliego de Licitación Pública - Obras Viales</span>\n                </div>\n              </td>\n              <td class=\"px-6 py-4\" data-kid=\"143\"><span class=\"px-2 py-1 bg-orange-50 text-orange-600 rounded text-[10px] font-bold uppercase\" data-kid=\"144\">Transparencia</span></td>\n              <td class=\"px-6 py-4 text-sm text-gray-500\" data-kid=\"145\">08/10/2024</td>\n              <td class=\"px-6 py-4 text-right\" data-kid=\"146\">\n                <button class=\"text-aqua hover:text-navy transition-colors\" data-kid=\"147\">\n                  <i class=\"ti ti-download text-xl\" data-kid=\"148\"></i>\n                </button>\n              </td>\n            </tr>\n          </tbody>\n        </table>\n      </div>\n    </section>\n  </main>\n\n  \n  <footer class=\"bg-navy text-white mt-20 py-12\" data-kid=\"149\">\n    <div class=\"max-w-[1200px] mx-auto px-4 grid grid-cols-1 md:grid-cols-4 gap-12\" data-kid=\"150\">\n      <div class=\"space-y-4\" data-kid=\"151\">\n        <h5 class=\"font-heading text-lg font-bold border-l-4 border-aqua pl-3\" data-kid=\"152\">Contacto</h5>\n        <p class=\"text-sm text-gray-300\" data-kid=\"153\">Calle Principal No. 123, Centro Histórico</p>\n        <p class=\"text-sm text-gray-300\" data-kid=\"154\">Tel: (555) 0123-4567</p>\n        <p class=\"text-sm text-gray-300\" data-kid=\"155\">atencion@municipio.gob</p>\n      </div>\n      <div class=\"space-y-4\" data-kid=\"156\">\n        <h5 class=\"font-heading text-lg font-bold border-l-4 border-aqua pl-3\" data-kid=\"157\">Enlaces</h5>\n        <ul class=\"text-sm text-gray-300 space-y-2\" data-kid=\"158\">\n          <li data-kid=\"159\"><a href=\"#\" class=\"hover:text-aqua transition-colors\" data-kid=\"160\">Portal de Transparencia</a></li>\n          <li data-kid=\"161\"><a href=\"#\" class=\"hover:text-aqua transition-colors\" data-kid=\"162\">Mesa de Partes Virtual</a></li>\n          <li data-kid=\"163\"><a href=\"#\" class=\"hover:text-aqua transition-colors\" data-kid=\"164\">Directorio de Funcionarios</a></li>\n        </ul>\n      </div>\n      <div class=\"space-y-4\" data-kid=\"165\">\n        <h5 class=\"font-heading text-lg font-bold border-l-4 border-aqua pl-3\" data-kid=\"166\">Síguenos</h5>\n        <div class=\"flex gap-4\" data-kid=\"167\">\n          <a href=\"#\" class=\"w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-aqua transition-all\" data-kid=\"168\"><i class=\"ti ti-brand-facebook\" data-kid=\"169\"></i></a>\n          <a href=\"#\" class=\"w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-aqua transition-all\" data-kid=\"170\"><i class=\"ti ti-brand-twitter\" data-kid=\"171\"></i></a>\n          <a href=\"#\" class=\"w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-aqua transition-all\" data-kid=\"172\"><i class=\"ti ti-brand-instagram\" data-kid=\"173\"></i></a>\n        </div>\n      </div>\n      <div class=\"flex flex-col items-center justify-center gap-4\" data-kid=\"174\">\n        <img src=\"/api/local/images/public/images/institution/institution-logo.png\" alt=\"Logo Municipal Footer\" class=\"h-20 w-auto brightness-0 invert opacity-60\" decoding=\"async\" loading=\"lazy\" data-kid=\"175\">\n        <p class=\"text-[10px] text-gray-400 uppercase tracking-widest\" data-kid=\"176\">&copy; 2024 Gobierno Municipal</p>\n      </div>\n    </div>\n  </footer>\n</div>",
